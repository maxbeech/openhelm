{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenHelm",
  "version": "0.7.0",
  "identifier": "com.maxbeech.openhelm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "targets": "all",
    "externalBin": ["binaries/agent"],
    "resources": ["bundled-node-modules/**/*", "bundled-node/**/*", "mcp-servers/browser/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "notification": null,
    "autostart": null,
    "updater": {
      "dialog": false,
      "endpoints": [
        "https://raw.githubusercontent.com/maxbeech/openhelm/main/update-manifest/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBMjFBRTdFM0UyNjc0QUYKUldTdmRDWStmcTRoU2tZdE1sTk9yYmRmMWJHeDF5N1BXelZlWGEyRitaVlFzc3ZhOXYwYW5sRDgK"
    }
  }
}
