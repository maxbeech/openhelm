{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenHelm",
  "version": "0.1.2",
  "identifier": "com.maxbeech.openhelm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/agent"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "notification": null,
    "autostart": null,
    "updater": {
      "dialog": false,
      "endpoints": [
        "https://raw.githubusercontent.com/openhelm/openhelm/main/update-manifest/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEMjY4QjJCQUQxNjg3QTgKUldTb2h4YXRLNHNtN1c2R3puVnZYRkJDc3A3bytkWHR6VG9WcWFkRFcyU3FrK1pkTEx5RS94RmcK"
    }
  }
}
