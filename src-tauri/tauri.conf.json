{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenOrchestra",
  "version": "0.1.0",
  "identifier": "ai.openorchestra.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "OpenOrchestra",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/agent"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "notification": {
      "registerForRemoteNotifications": false
    },
    "autostart": {
      "macosLauncher": "LaunchAgent"
    },
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/openorchestra/openorchestra/releases/latest/download/latest.json"
      ]
    }
  }
}
