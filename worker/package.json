{
  "name": "@openhelm/worker",
  "version": "0.1.0",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs --external:@anthropic-ai/sdk --external:openai --external:e2b --external:@e2b/desktop --external:@supabase/supabase-js",
    "start": "node dist/index.cjs",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='__tests__'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@e2b/desktop": "^1.9.2",
    "@supabase/supabase-js": "^2.50.0",
    "e2b": "^1.4.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
