{
  "name": "openhelm",
  "version": "0.1.0",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "workspaces": [
    "agent",
    "shared"
  ],
  "scripts": {
    "predev": "lsof -ti tcp:1420 2>/dev/null | xargs kill -9 2>/dev/null; exit 0",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "npm run test --workspace=agent && npx vitest run --config vitest.config.ts",
    "test:ui": "npx vitest run --config vitest.config.ts",
    "test:agent": "npm run test --workspace=agent",
    "lint": "eslint .",
    "tauri": "tauri",
    "tauri:build": "tauri build && node scripts/patch-bundle.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/node": "^10.46.0",
    "@sentry/react": "^10.46.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "posthog-js": "^1.364.3",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.19.0",
    "jsdom": "^28.1.0",
    "rollup": "^4.60.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.1"
  }
